{
  "name": "trabalho-final-cloud-cli",
  "version": "1.0.0",
  "description": "CLI para criar recursos AWS (EC2, RDS, Load Balancer, S3)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "aws",
    "cli",
    "cloud"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1072.0",
    "@aws-sdk/client-ec2-instance-connect": "^3.1072.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1072.0",
    "@aws-sdk/client-rds": "^3.1072.0",
    "@aws-sdk/client-s3": "^3.1072.0",
    "@clack/prompts": "^0.11.0"
  }
}
